---
import Layout from '../layouts/Layout.astro';
import StatsCard from '../components/StatsCard.astro';
import NewsCard from '../components/NewsCard.astro';
import { createClient } from '@supabase/supabase-js';

const supabase = createClient(
  import.meta.env.PUBLIC_SUPABASE_URL,
  import.meta.env.PUBLIC_SUPABASE_ANON_KEY
);

const chartUrl = "https://uyakfgtlltexwhzlceai.supabase.co/storage/v1/object/public/charts/daily.png";

const alt = "Dark line chart of Dystopia Fund daily percent returns over the last 90 days with a bold 7-day rolling average line.";

const { data: latestSnapshot } = await supabase
  .from('portfolio_snapshots')
  .select('*')
  .order('timestamp', { ascending: false })
  .limit(1)
  .single();

const { data: blogPosts } = await supabase
  .from('blog_posts')
  .select('id, title, slug, excerpt, published_at')
  .eq('is_published', true)
  .order('published_at', { ascending: false })
  .limit(3);

const { data: newsEditor } = await supabase
  .from('news_editor')
  .select('id, title, slug, published_at')
  .eq('is_published', true)
  .order('published_at', { ascending: false })
  .limit(3);

const { data: generatedImages } = await supabase
  .from('generated_images')
  .select('id, title, image_url, slug, created_at')
  .eq('is_published', true)
  .order('created_at', { ascending: false })
  .limit(4);

function visionImg(url: string, width = 900) {
  if (!url) return url;
  return url
    .replace('/storage/v1/object/public/', '/storage/v1/render/image/public/')
    + `?width=${width}&quality=72&format=webp`;
}

const featuredImage = generatedImages?.[0] ?? null;
const scrollerImages = generatedImages ?? [];
const featuredImageHref = featuredImage?.slug ? `/news/${featuredImage.slug}` : '/visions';

const { data: newsArticles } = await supabase
  .from('news_articles_dystopia')
  .select('*')
  .order('published_at', { ascending: false })
  .limit(20);

const stats = latestSnapshot ? {
  dailyPL: parseFloat(latestSnapshot.daily_pl || 0),
  dailyPLPercent: parseFloat(latestSnapshot.daily_pl_percent || 0),
  totalValue: parseFloat(latestSnapshot.total_value || 0),
  topGainer: latestSnapshot.top_gainers?.[0],
  topLoser: latestSnapshot.top_losers?.[0]
} : null;
---

<Layout title="The Dystopia Fund">
  <div class="bg-gradient-to-br from-slate-900 via-slate-800 to-slate-900 text-white relative overflow-hidden">
    <div class="absolute inset-0 bg-[url('/Gemini_Generated_Image_w9l5d5w9l5d5w9l5.png')] bg-no-repeat bg-right bg-cover opacity-40"></div>

    <div class="max-w-7xl mx-auto px-4 py-16 relative z-10">
      <div class="max-w-3xl">
        <h1 class="text-4xl md:text-5xl font-bold mb-4 leading-tight">
          Investing in Societal Dysfunction
        </h1>
        <p class="text-xl text-slate-300 mb-8">
          When civil unrest becomes profitable, we capitalize. The Dystopia Fund tracks the correlation between social breakdown and market performance.
        </p>

        {stats && (
          <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
            <div class="bg-white/10 backdrop-blur-sm border border-white/20 p-4 rounded-lg">
              <div class="text-slate-400 text-sm mb-1">YTD Return</div>
              <div class={`text-2xl font-bold ${stats.dailyPL >= 0 ? 'text-green-400' : 'text-red-400'}`}>
                {stats.dailyPLPercent >= 0 ? '+' : ''}{stats.dailyPLPercent}%
              </div>
            </div>
            <div class="bg-white/10 backdrop-blur-sm border border-white/20 p-4 rounded-lg">
              <div class="text-slate-400 text-sm mb-1">Portfolio Value</div>
              <div class="text-2xl font-bold">${stats.totalValue.toLocaleString()}</div>
            </div>
            <div class="bg-white/10 backdrop-blur-sm border border-white/20 p-4 rounded-lg col-span-2 md:col-span-1">
              <div class="text-slate-400 text-sm mb-1">Strategy</div>
              <div class="text-2xl font-bold">Dystopia 50</div>
            </div>
          </div>
        )}
      </div>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-4 py-12">
    {stats && (
      <div class="mb-12">
        <h2 class="text-2xl font-bold text-slate-900 mb-6">Performance Overview</h2>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
          <StatsCard
            label="24H P&L"
            value={`${stats.dailyPL >= 0 ? '+' : ''}$${stats.dailyPL.toFixed(2)}`}
            subValue={`${stats.dailyPLPercent >= 0 ? '+' : ''}${stats.dailyPLPercent}%`}
            trend={stats.dailyPL >= 0 ? 'up' : 'down'}
            highlight={true}
          />
          <StatsCard
            label="Portfolio Value"
            value={`$${stats.totalValue.toLocaleString()}`}
            subValue="USD"
            trend="neutral"
          />
          {stats.topGainer && (
            <StatsCard
              label="Top Gainer"
              value={stats.topGainer.symbol}
              subValue={`+${stats.topGainer.plPercent}%`}
              trend="up"
            />
          )}
          {stats.topLoser && (
            <StatsCard
              label="Top Loser"
              value={stats.topLoser.symbol}
              subValue={`${stats.topLoser.plPercent}%`}
              trend="down"
            />
          )}
        </div>
      </div>
    )}

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      <div class="lg:col-span-2 space-y-8">
        {featuredImage && (
          <section>
            <div class="mb-4 flex items-center justify-between gap-4">
              <h2 class="text-2xl font-bold text-slate-900">Latest Vision</h2>
              <a
                href="/visions"
                class="inline-flex items-center gap-2 text-sm text-slate-500 hover:text-slate-900 transition-colors"
              >
                See all visions
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                </svg>
              </a>
            </div>

            <a
              href={featuredImageHref}
              class="group block overflow-hidden rounded-lg border border-slate-200 bg-slate-950 shadow-sm"
            >
              <div class="relative aspect-[16/10] overflow-hidden">
                <img
                  src={visionImg(featuredImage.image_url, 1200)}
                  alt={featuredImage.title ?? 'AI Dystopian Vision'}
                  class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-[1.02]"
                  loading="eager"
                />
                <div class="absolute inset-0 bg-gradient-to-t from-slate-950 via-slate-950/50 to-transparent"></div>
                <div class="absolute inset-x-0 bottom-0 p-6">
                  <p class="mb-2 text-xs font-mono uppercase tracking-[0.25em] text-red-400">AI Vision</p>
                  <h3 class="max-w-2xl text-2xl font-bold leading-snug text-white">
                    {featuredImage.title ?? 'Untitled Vision'}
                  </h3>
                </div>
              </div>
            </a>

            {scrollerImages.length > 1 && (
              <div class="mt-4 flex gap-3 overflow-x-auto pb-1 scrollbar-hide" style="scroll-snap-type:x mandatory">
                {scrollerImages.map((img) => (
                  <a
                    href="/visions"
                    class="group flex-none w-44 rounded-lg overflow-hidden border border-slate-200 bg-white hover:border-red-300 transition-all duration-200"
                    style="scroll-snap-align:start"
                  >
                    <div class="relative aspect-square overflow-hidden bg-slate-100">
                      <img
                        src={visionImg(img.image_url, 300)}
                        alt={img.title ?? 'Vision'}
                        loading="lazy"
                        class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                      />
                    </div>
                    <div class="px-3 py-3">
                      <p class="text-xs font-medium text-slate-800 line-clamp-1 group-hover:text-slate-950 transition-colors">
                        {img.title ?? 'Untitled'}
                      </p>
                      <p class="mt-1 text-[10px] font-mono text-slate-500">
                        {new Date(img.created_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}
                      </p>
                    </div>
                  </a>
                ))}
                <a
                  href="/visions"
                  class="flex-none w-44 rounded-lg border border-dashed border-slate-300 bg-slate-50 hover:border-red-300 flex flex-col items-center justify-center gap-2 p-4 text-center text-slate-500 hover:text-red-500 transition-all duration-200"
                  style="scroll-snap-align:start; min-height:160px"
                >
                  <span class="text-2xl">All</span>
                  <span class="text-xs font-mono">View archive</span>
                </a>
              </div>
            )}
          </section>
        )}

        <div>
          <h2 class="text-2xl font-bold text-slate-900 mb-4">Latest Analysis</h2>
          <div class="space-y-3">
            {newsEditor?.map(post => (
              <NewsCard
                title={post.title}
                source="Editorial"
                date={new Date(post.published_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
                url={`/news/${post.slug}`}
                category="Observation"
              />
            ))}
          </div>
        </div>

        <div>
          <h2 class="text-2xl font-bold text-slate-900 mb-4">Research & Commentary</h2>
          <div class="space-y-3">
            {blogPosts?.map(post => (
              <NewsCard
                title={post.title}
                source="Blog"
                date={new Date(post.published_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
                url={`/blog/${post.slug}`}
                category="Analysis"
              />
            ))}
          </div>
        </div>

        <div>
          <h2 class="text-2xl font-bold text-slate-900 mb-4">90-Day Performance</h2>
          <div class="bg-white border border-slate-200 rounded-lg p-4">
            <img src={chartUrl} alt={alt} width="1200" height="600" loading="lazy" class="w-full h-auto rounded" />
          </div>
        </div>
      </div>

      <div class="lg:col-span-1">
        <div class="lg:sticky lg:top-4">
          <div class="flex items-center justify-between mb-4">
            <h2 class="text-xl font-bold text-slate-900">Market Signals</h2>
            <span class="text-xs font-medium text-accent-blue uppercase tracking-wide">Live Feed</span>
          </div>

          <div class="space-y-3 max-h-[calc(100vh-150px)] overflow-y-auto pr-2">
            {newsArticles?.map(article => (
              <NewsCard
                title={article.title}
                source={article.source}
                date={article.search_query}
                url={article.url}
                score={parseFloat(article.dystopia_score).toFixed(1)}
              />
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>
