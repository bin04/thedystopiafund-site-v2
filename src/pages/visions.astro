---
import Layout from '../layouts/Layout.astro';
import { createClient } from '@supabase/supabase-js';

const supabase = createClient(
  import.meta.env.PUBLIC_SUPABASE_URL,
  import.meta.env.PUBLIC_SUPABASE_ANON_KEY
);

const { data: initialImages } = await supabase
  .from('generated_images')
  .select('id, title, image_url, slug, prompt, created_at')
  .eq('is_published', true)
  .order('created_at', { ascending: false })
  .limit(12);

const images = initialImages ?? [];
const hasMore = images.length === 12;
---

<Layout title="Visions | The Dystopia Fund">
  <div class="min-h-screen bg-slate-950">

    {/* PAGE HEADER */}
    <div class="relative overflow-hidden border-b border-slate-800">
      <div class="absolute inset-0 bg-gradient-to-br from-red-950/40 via-slate-950 to-slate-950 pointer-events-none"></div>
      <div class="max-w-7xl mx-auto px-4 py-14 relative z-10">
        <div class="flex items-end justify-between gap-4">
          <div>
            <p class="text-red-400 text-xs font-mono uppercase tracking-widest mb-3">AI · Generated · Imagery</p>
            <h1 class="text-4xl md:text-5xl font-bold text-white leading-tight">
              Dystopia<span class="text-red-500">.</span> Visions
            </h1>
            <p class="text-slate-400 mt-3 max-w-xl text-base">
              Every eight hours, The Dystopia Fund's AI reads the market's despair and renders it. These are its hallucinations.
            </p>
          </div>
          <a href="/" class="hidden sm:flex items-center gap-2 text-sm text-slate-500 hover:text-slate-300 transition-colors whitespace-nowrap">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
            </svg>
            Back to Home
          </a>
        </div>
      </div>
    </div>

    {/* GALLERY GRID */}
    <div class="max-w-7xl mx-auto px-4 py-10">

      <div id="visions-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {images.map((img) => (
          <article
            class="group relative bg-slate-900 rounded-xl overflow-hidden border border-slate-800 hover:border-red-900/60 transition-all duration-300 hover:shadow-2xl hover:shadow-red-950/30 hover:-translate-y-0.5"
            data-id={img.id}
          >
            {/* IMAGE */}
            <div class="relative aspect-video overflow-hidden bg-slate-800">
              <a
                href={img.image_url}
                download
                target="_blank"
                rel="noopener noreferrer"
                class="block h-full w-full"
                aria-label={`Download ${img.title ?? 'dystopian vision'}`}
                title="Open or download full image"
              >
                <img
                  src={img.image_url}
                  alt={img.title ?? 'Dystopian vision'}
                  loading="lazy"
                  class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                />
              </a>
              {/* Gradient overlay */}
              <div class="pointer-events-none absolute inset-0 bg-gradient-to-t from-slate-900 via-transparent to-transparent opacity-70"></div>
            </div>

            {/* CARD BODY */}
            <div class="p-4">
              <h2 class="text-white font-semibold text-sm leading-snug mb-1 line-clamp-2 group-hover:text-red-300 transition-colors">
                {img.title ?? 'Untitled Vision'}
              </h2>
              <div class="flex items-center justify-between mt-3">
                <time class="text-slate-500 text-xs font-mono">
                  {new Date(img.created_at).toLocaleDateString('en-US', {
                    month: 'short', day: 'numeric', year: 'numeric'
                  })}
                </time>
                {img.slug && (
                  <a
                    href={`/news/${img.slug}`}
                    class="text-xs text-red-500/70 hover:text-red-400 transition-colors font-mono"
                    title="View the digest that inspired this image"
                  >
                    → source
                  </a>
                )}
              </div>
              {/* Prompt peek on hover */}
              <p class="mt-3 text-slate-600 text-xs line-clamp-2 leading-relaxed group-hover:text-slate-500 transition-colors font-mono">
                {img.prompt?.slice(0, 120)}{img.prompt && img.prompt.length > 120 ? '…' : ''}
              </p>
            </div>
          </article>
        ))}
      </div>

      {/* Loading skeleton template (hidden) */}
      <template id="skeleton-tpl">
        <div class="bg-slate-900 rounded-xl overflow-hidden border border-slate-800 animate-pulse">
          <div class="aspect-video bg-slate-800"></div>
          <div class="p-4 space-y-2">
            <div class="h-3 bg-slate-800 rounded w-3/4"></div>
            <div class="h-3 bg-slate-800 rounded w-1/2"></div>
          </div>
        </div>
      </template>

      {/* LOAD MORE */}
      {hasMore && (
        <div class="mt-12 text-center">
          <button
            id="load-more-btn"
            class="group relative inline-flex items-center gap-2 px-8 py-3 bg-transparent border border-red-800/50 text-red-400 rounded-lg font-mono text-sm hover:bg-red-950/30 hover:border-red-700 transition-all duration-200"
          >
            <span id="load-more-label">Load More Visions</span>
            <svg id="load-more-spinner" class="hidden w-4 h-4 animate-spin" fill="none" viewBox="0 0 24 24">
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
              <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
            </svg>
          </button>
          <p id="no-more-label" class="hidden text-slate-600 text-sm font-mono mt-4">— End of the archive —</p>
        </div>
      )}

      {/* Empty state */}
      {images.length === 0 && (
        <div class="text-center py-24">
          <div class="text-6xl mb-4">🖼️</div>
          <h2 class="text-slate-400 text-xl font-semibold mb-2">No visions yet</h2>
          <p class="text-slate-600 text-sm">The AI is still contemplating the abyss. Check back soon.</p>
        </div>
      )}
    </div>
  </div>
</Layout>

<script>
  const SUPABASE_URL = import.meta.env.PUBLIC_SUPABASE_URL;
  const SUPABASE_ANON_KEY = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;
  const PAGE_SIZE = 12;

  let offset = document.querySelectorAll('#visions-grid article').length;
  let loading = false;
  let exhausted = false;

  const grid = document.getElementById('visions-grid');
  const btn  = document.getElementById('load-more-btn');
  const label = document.getElementById('load-more-label');
  const spinner = document.getElementById('load-more-spinner');
  const noMore = document.getElementById('no-more-label');
  const tpl = document.getElementById('skeleton-tpl') as HTMLTemplateElement;

  function createCard(img: any): string {
    const date = new Date(img.created_at).toLocaleDateString('en-US', {
      month: 'short', day: 'numeric', year: 'numeric'
    });
    const imageTitle = img.title ?? 'Untitled Vision';
    const promptSnippet = img.prompt
      ? img.prompt.slice(0, 120) + (img.prompt.length > 120 ? '…' : '')
      : '';
    const sourceLink = img.slug
      ? `<a href="/news/${img.slug}" class="text-xs text-red-500/70 hover:text-red-400 transition-colors font-mono" title="View the digest that inspired this image">→ source</a>`
      : '';

    return `
      <article class="group relative bg-slate-900 rounded-xl overflow-hidden border border-slate-800 hover:border-red-900/60 transition-all duration-300 hover:shadow-2xl hover:shadow-red-950/30 hover:-translate-y-0.5" data-id="${img.id}">
        <div class="relative aspect-video overflow-hidden bg-slate-800">
          <a href="${img.image_url}" download target="_blank" rel="noopener noreferrer" class="block h-full w-full" aria-label="Download ${imageTitle}" title="Open or download full image">
            <img src="${img.image_url}" alt="${imageTitle}" loading="lazy"
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" />
          </a>
          <div class="pointer-events-none absolute inset-0 bg-gradient-to-t from-slate-900 via-transparent to-transparent opacity-70"></div>
        </div>
        <div class="p-4">
          <h2 class="text-white font-semibold text-sm leading-snug mb-1 line-clamp-2 group-hover:text-red-300 transition-colors">
            ${imageTitle}
          </h2>
          <div class="flex items-center justify-between mt-3">
            <time class="text-slate-500 text-xs font-mono">${date}</time>
            ${sourceLink}
          </div>
          <p class="mt-3 text-slate-600 text-xs line-clamp-2 leading-relaxed group-hover:text-slate-500 transition-colors font-mono">
            ${promptSnippet}
          </p>
        </div>
      </article>`;
  }

  async function loadMore() {
    if (loading || exhausted) return;
    loading = true;

    // Show button loading state
    label!.textContent = 'Loading…';
    spinner!.classList.remove('hidden');
    btn!.setAttribute('disabled', 'true');

    // Add skeletons
    const skeletons: Element[] = [];
    for (let i = 0; i < 3; i++) {
      const clone = tpl!.content.cloneNode(true) as DocumentFragment;
      const el = clone.firstElementChild!;
      grid!.appendChild(clone);
      skeletons.push(grid!.lastElementChild!);
    }

    try {
      const from = offset;
      const to = offset + PAGE_SIZE - 1;
      const res = await fetch(
        `${SUPABASE_URL}/rest/v1/generated_images?select=id,title,image_url,slug,prompt,created_at&is_published=eq.true&order=created_at.desc&offset=${from}&limit=${PAGE_SIZE}`,
        {
          headers: {
            apikey: SUPABASE_ANON_KEY,
            Authorization: `Bearer ${SUPABASE_ANON_KEY}`,
          }
        }
      );
      const data = await res.json();

      // Remove skeletons
      skeletons.forEach(s => s.remove());

      if (!data || data.length === 0) {
        exhausted = true;
        btn!.style.display = 'none';
        noMore!.classList.remove('hidden');
        return;
      }

      // Inject new cards
      const html = data.map(createCard).join('');
      grid!.insertAdjacentHTML('beforeend', html);
      offset += data.length;

      if (data.length < PAGE_SIZE) {
        exhausted = true;
        btn!.style.display = 'none';
        noMore!.classList.remove('hidden');
      }
    } catch (err) {
      console.error('Failed to load more visions', err);
      skeletons.forEach(s => s.remove());
    } finally {
      loading = false;
      label!.textContent = 'Load More Visions';
      spinner!.classList.add('hidden');
      btn!.removeAttribute('disabled');
    }
  }

  btn?.addEventListener('click', loadMore);
</script>
