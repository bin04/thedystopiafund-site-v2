---
interface Props {
  title?: string;
  darkMode?: boolean;
}

const { title, darkMode = false } = Astro.props;
---

<!doctype html>
<html lang="en" class="h-full">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Your Misery, Our Dividends" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0"
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet">
    <title>{title ? title : "The Dystopia Fund"}</title>
  </head>
  <body class={darkMode ? "bg-slate-900 text-slate-100 min-h-screen flex flex-col font-sans" : "bg-slate-50 text-slate-900 min-h-screen flex flex-col font-sans"}>
    {/* NAV */}
    <nav class="bg-white border-b border-slate-200 shadow-sm">
      <div class="w-full max-w-7xl mx-auto px-4 py-4">
        <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
          <a
            href="/"
            class="text-xl sm:text-2xl font-bold text-slate-900 leading-tight tracking-tight flex items-center gap-2"
          >
            <span class="text-2xl">💀</span> 
            <span>The Dystopia Fund</span>
          </a>
          <div
            class="flex flex-wrap gap-x-6 gap-y-2 text-sm font-medium"
          >
            <a href="/" class="text-slate-600 hover:text-slate-900 transition-colors">Home</a>
            <a href="/predictions" class="text-slate-600 hover:text-slate-900 transition-colors">Predictions</a>
            <a href="/portfolio" class="text-slate-600 hover:text-slate-900 transition-colors">Portfolio</a>
            <a href="/contracts" class="text-slate-600 hover:text-slate-900 transition-colors">Contracts</a>
            <a href="/roster" class="text-slate-600 hover:text-slate-900 transition-colors">Roster</a>
            <a href="/feed" class="text-slate-600 hover:text-slate-900 transition-colors">Feed</a>
            <a href="/fakenews" class="text-slate-600 hover:text-slate-900 transition-colors">Fake News</a>
            <a href="/visions" class="text-slate-600 hover:text-slate-900 transition-colors">Visions</a>
            <a href="/about" class="text-slate-600 hover:text-slate-900 transition-colors">About</a>
          </div>
        </div>
      </div>
    </nav>

    {/* MAIN */}
    <main class="flex-1 w-full">
      {/* Each page (feed, etc.) should wrap content in:
          <div class="w-full max-w-6xl mx-auto px-4 py-6">...</div>
      */}
      <slot />
    </main>

    {/* FOOTER */}
    <footer class="bg-white border-t border-slate-200 mt-auto">
      <div class="w-full max-w-7xl mx-auto px-4 py-8 text-center text-slate-600 text-sm">
        <p class="mb-3 font-medium text-slate-700">Your Misery, Our Dividends</p>
        <div class="flex flex-wrap justify-center gap-4">
          <a
            href="https://twitter.com/DystopiaFund"
            target="_blank"
            rel="noopener"
            class="hover:text-slate-900 transition-colors"
          >
            @DystopiaFund
          </a>
          <span class="text-slate-300">•</span>
          <a
            href="mailto:dystopiafund@gmail.com"
            class="hover:text-slate-900 transition-colors"
          >
            dystopiafund@gmail.com
          </a>
        </div>
      </div>
    </footer>
  </body>
</html>
